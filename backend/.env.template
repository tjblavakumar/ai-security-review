# =============================================================================
# AI/GenAI Security Review - Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env and update the values
# All settings are required unless marked as optional
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/ai_security_review.db

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_TITLE=AI/GenAI Security Review
APP_VERSION=0.2.0
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# =============================================================================
# LLM PROVIDER CONFIGURATION
# Choose one: openai, litellm, or bedrock
# =============================================================================
LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# Option 1: OpenAI (Cloud-based AI)
# Get your API key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Option 2: LiteLLM (Local/Self-hosted AI)
# Requires: Ollama + LiteLLM proxy
# Setup: See backend/docs/MULTI_PROVIDER_LLM.md
# -----------------------------------------------------------------------------
# LLM_PROVIDER=litellm
# LITELLM_API_BASE=http://localhost:4000
# LITELLM_API_KEY=sk-1234
# LITELLM_MODEL_ID=ollama/llama2
# LITELLM_VISION_MODEL_ID=ollama/llava
# LITELLM_EMBEDDING_MODEL=ollama/nomic-embed-text

# -----------------------------------------------------------------------------
# Option 3: AWS Bedrock (Enterprise AI)
# Requires: AWS account with Bedrock enabled
# Models: Claude, Titan, etc.
# -----------------------------------------------------------------------------
# LLM_PROVIDER=bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# General AI Settings (applies to all providers)
# -----------------------------------------------------------------------------
AI_SUGGESTION_ENABLED=true
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

# =============================================================================
# QUICK START EXAMPLES
# =============================================================================

# Example 1: OpenAI (Recommended for getting started)
# ----------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-abc123xyz...
# (Keep other OpenAI settings as default)

# Example 2: Local AI with Ollama (Free & Private)
# -------------------------------------------------
# 1. Install Ollama: curl -fsSL https://ollama.com/install.sh | sh
# 2. Pull models: ollama pull llama2 && ollama pull nomic-embed-text
# 3. Start proxy: litellm --model ollama/llama2 --port 4000
# 4. Configure:
#    LLM_PROVIDER=litellm
#    LITELLM_API_BASE=http://localhost:4000
#    LITELLM_MODEL_ID=ollama/llama2
#    LITELLM_EMBEDDING_MODEL=ollama/nomic-embed-text

# Example 3: AWS Bedrock (Enterprise)
# ------------------------------------
# 1. Enable models in AWS Bedrock console
# 2. Configure AWS credentials (aws configure)
# 3. Configure:
#    LLM_PROVIDER=bedrock
#    BEDROCK_REGION=us-east-1
#    BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
#    BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# =============================================================================
# TESTING YOUR CONFIGURATION
# =============================================================================
# Run: python backend/test_llm_provider.py
# Check: GET http://localhost:8000/api/ai/status

# =============================================================================
# IMPORTANT NOTES
# =============================================================================
# - When switching providers, RE-INDEX all policy documents
# - Different providers create incompatible embeddings
# - Test your config before deploying: python backend/test_llm_provider.py
# - Full guide: backend/docs/MULTI_PROVIDER_LLM.md
