# =============================================================================
# AI/GenAI Security Review - Minimal Configuration
# =============================================================================
# Quick Start: Copy this to .env and configure only your chosen provider
# cp .env.minimal backend/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/ai_security_review.db

# -----------------------------------------------------------------------------
# Application Settings (REQUIRED)
# -----------------------------------------------------------------------------
APP_TITLE=AI/GenAI Security Review
APP_VERSION=0.2.0
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# File Upload Settings (REQUIRED)
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# -----------------------------------------------------------------------------
# General AI Settings (REQUIRED)
# -----------------------------------------------------------------------------
AI_SUGGESTION_ENABLED=true
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

# =============================================================================
# LLM PROVIDER - Choose ONE option below
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION 1: OpenAI (Cloud-based, easiest setup)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-key-here
# Optional: Uncomment to customize
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# OPTION 2: LiteLLM (Local AI, free)
# Uncomment these lines if using LiteLLM
# -----------------------------------------------------------------------------
# LLM_PROVIDER=litellm
# LITELLM_API_BASE=http://localhost:4000
# LITELLM_MODEL_ID=ollama/llama2
# LITELLM_EMBEDDING_MODEL=ollama/nomic-embed-text
# Optional: Uncomment to customize
# LITELLM_API_KEY=sk-1234
# LITELLM_VISION_MODEL_ID=ollama/llava

# -----------------------------------------------------------------------------
# OPTION 3: AWS Bedrock (Enterprise)
# Uncomment these lines if using Bedrock
# -----------------------------------------------------------------------------
# LLM_PROVIDER=bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# Optional: Uncomment to customize
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# THAT'S IT! Start the server:
# python -m uvicorn app.main:app --reload --port 8000
# =============================================================================
